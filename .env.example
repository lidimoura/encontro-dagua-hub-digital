# ===========================================
# NossoCRM - Environment Variables (EXAMPLE)
# ===========================================
# ⚠️  NUNCA commite o arquivo .env real — somente este .env.example
# ⚠️  NEVER commit real credentials — rotate any key that was exposed
# ===========================================

# Supabase (obrigatório)
# Obtenha em: Supabase Dashboard → Settings → API
VITE_SUPABASE_URL=https://SEU_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=COLE_AQUI_A_ANON_KEY

# Supabase Service Role — APENAS Vercel Secrets / CI / Edge Functions
# NUNCA exponha esta chave no frontend ou num arquivo commitado
# Obtenha em: Supabase Dashboard → Settings → API → Service Role Key
# Rotacione imediatamente se exposta: Dashboard → Settings → API → Regenerate
SUPABASE_SERVICE_ROLE_KEY=COLE_AQUI_APENAS_EM_SECRETS_NUNCA_NO_CODIGO

# Google Gemini AI (opcional - para features de IA)
# Obtenha em: https://aistudio.google.com/apikey
VITE_GEMINI_API_KEY=COLE_AQUI_A_GEMINI_KEY
VITE_GEMINI_API_KEY_SECONDARY=COLE_AQUI_A_GEMINI_KEY_RESERVA
GEMINI_API_KEY=IDEM_ACIMA

# N8N Webhook Integration (opcional - para QR d'água)
VITE_N8N_WEBHOOK_URL=https://SEU_N8N_HOST/webhook/seu-webhook-id

# Stripe (opcional - para checkout)
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_COLE_AQUI_A_PUBLISHABLE_KEY

# VAPID Web Push Notifications (apenas chave pública no frontend)
VITE_VAPID_PUBLIC_KEY=COLE_AQUI_A_VAPID_PUBLIC_KEY

# Lead Gate (opcional - sobrescreve o valor default)
VITE_ACCESS_KEYWORD=ReflorestarDigital

# Analytics
VITE_GA4_ID=G-XXXXXXXXXX
