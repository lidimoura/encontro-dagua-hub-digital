# Supabase (obrigatório)
# Obtenha em: Supabase Dashboard → Settings → API
VITE_SUPABASE_URL=https://iztcxuwqryjnioczogpr.supabase.co
VITE_SUPABASE_ANON_KEY=PLACEHOLDER_JWT_REMOVED

# Supabase Service Role (apenas para GitHub Actions)
# NUNCA exponha em produção - apenas para CI/CD
# Obtenha em: Supabase Dashboard → Settings → API → Service Role
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key

# Google Gemini AI (opcional - para features de IA)
# Obtenha em: https://aistudio.google.com/apikey
VITE_GEMINI_API_KEY=PLACEHOLDER_GEMINI_KEY

# Legacy (manter para compatibilidade)
GEMINI_API_KEY=PLACEHOLDER_GEMINI_KEY

# N8N Webhook Integration (opcional - para QR d'água)
# Configure o webhook no seu N8N e cole a URL aqui
VITE_N8N_WEBHOOK_URL=https://n8n-service-cc94.onrender.com/webhook-test/qr-dagua-crm

